{
	"info": {
		"_postman_id": "85e1bf81-2823-4176-9956-7929b393df4a",
		"name": "用户管理",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "获取所有用户",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"// 断言1：状态码是 200\r",
							"pm.test(\"状态码是 200\", function () {\r",
							"    pm.response.to.have.status(200);\r",
							"});\r",
							"\r",
							"// 断言2：返回的数据是一个数组（列表）\r",
							"pm.test(\"返回数据是数组\", function () {\r",
							"    var jsonData = pm.response.json();\r",
							"    pm.expect(jsonData).to.be.an('array');\r",
							"});\r",
							"\r",
							"// 断言3：数组中第一个用户的 id 是 1\r",
							"pm.test(\"第一个用户ID是1\", function () {\r",
							"    var jsonData = pm.response.json();\r",
							"    pm.expect(jsonData[0].id).to.eql(1);\r",
							"});\r",
							"\r",
							"// 断言4：数组中第一个用户的 name 是 Leanne Graham\r",
							"pm.test(\"第一个用户名是Leanne Graham\", function () {\r",
							"    var jsonData = pm.response.json();\r",
							"    pm.expect(jsonData[0].name).to.eql(\"Leanne Graham\");\r",
							"});\r",
							"\r",
							"// 断言5：数组长度大于0（说明有数据）\r",
							"pm.test(\"数组不为空\", function () {\r",
							"    var jsonData = pm.response.json();\r",
							"    pm.expect(jsonData.length).to.be.above(0);\r",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "https://jsonplaceholder.typicode.com/users",
					"protocol": "https",
					"host": [
						"jsonplaceholder",
						"typicode",
						"com"
					],
					"path": [
						"users"
					]
				}
			},
			"response": []
		},
		{
			"name": "获取单个用户",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							""
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "https://jsonplaceholder.typicode.com/users/1",
					"protocol": "https",
					"host": [
						"jsonplaceholder",
						"typicode",
						"com"
					],
					"path": [
						"users",
						"1"
					]
				}
			},
			"response": []
		},
		{
			"name": "创建新用户",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"// 断言1\r",
							"pm.test(\"状态码201\", function () {\r",
							"    pm.response.to.have.status(201);\r",
							"});\r",
							"\r",
							"// 断言2\r",
							"pm.test(\"返回包含id\", function () {\r",
							"    pm.expect(pm.response.json()).to.have.property('id');\r",
							"});\r",
							"\r",
							"// 断言3\r",
							"pm.test(\"name是张三\", function () {\r",
							"    pm.expect(pm.response.json().name).to.eql(\"张三\");\r",
							"});\r",
							"\r",
							"// 【新增】提取id，保存到环境变量\r",
							"var jsonData = pm.response.json();\r",
							"pm.environment.set(\"new_user_id\", jsonData.id);"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\r\n    \"name\": \"张三\",\r\n    \"username\": \"zhangsan\",\r\n    \"email\": \"zhangsan@example.com\"\r\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{base_url}}/users",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"users"
					]
				}
			},
			"response": []
		},
		{
			"name": "查询刚创建的用户",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{base_url}}/users/{{new_user_id}}",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"users",
						"{{new_user_id}}"
					]
				}
			},
			"response": []
			
		}
	]
}
